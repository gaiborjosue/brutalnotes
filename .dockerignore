# BRUTAL NOTES - Docker ignore file
# Optimize build context by excluding unnecessary files

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist
build
.next

# Environment files (use build args instead)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode
.idea
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Version control
.git
.gitignore

# Testing
coverage
.nyc_output
.jest

# Logs
logs
*.log

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Optional npm cache directory
.npm

# ESLint cache
.eslintcache

# Typescript cache
*.tsbuildinfo

# Optional REPL history
.node_repl_history

# Temporary folders
tmp/
temp/

# Docker files (no need to copy these into the image)
Dockerfile*
docker-compose*
.dockerignore

# Documentation
README.md
*.md

# Package lock files (will be handled by npm ci)
package-lock.json
yarn.lock